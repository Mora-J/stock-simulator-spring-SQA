    {
      "name": "CP-08 Inyección SQL en Búsqueda",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El sistema no debe fallar con error interno (No 500)\", function () {\r",
              "    // Si escapa bien los caracteres, devolverá 200 (lista vacía) o 400 (Bad Request).\r",
              "    // Si devuelve 500, significa que la base de datos colapsó por la inyección.\r",
              "    pm.expect(pm.response.code).to.not.equal(500);\r",
              "});\r",
              "pm.test(\"El tiempo de respuesta debe ser normal (menor a 500ms)\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/stock/search?query=MSFT'; DROP TABLE users;",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "stock",
            "search"
          ],
          "query": [
            {
              "key": "query",
              "value": "MSFT'; DROP TABLE users;"
            }
          ]
        }
      },
      "response": []
    },

    {
      "name": "CP-11 Consultar Mercado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(500);\r",
              "});\r",
              "pm.test(\"La respuesta usa la estructura StockListResponseDTO (Es un json valido)\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"code\");\r",
              "    pm.expect(jsonData).to.have.property(\"stockDTOList\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
